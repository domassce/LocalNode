<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:LocalFileHosting.UI.ViewModels"
             x:Class="LocalFileHosting.UI.Views.HostedFilesView"
             x:DataType="vm:HostedFilesViewModel">

	<Grid RowDefinitions="Auto, *">

		<Grid Grid.Row="0" RowDefinitions="Auto, Auto" Margin="0,0,0,20">

			<Grid Grid.Row="0" ColumnDefinitions="*, Auto" Margin="0,0,0,8">


				<StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10">
					<Button Content="Go Back" Command="{Binding NavigateUpCommand}" IsVisible="{Binding CanNavigateUp}" Background="#2B2B40" Foreground="White" CornerRadius="6"/>
					<Button Content="Refresh" Command="{Binding RefreshFilesCommand}" Background="#2B2B40" Foreground="White" CornerRadius="6"/>
					<Button Content="+ Add File" Click="OnAddFileClicked" Background="#50CD89" Foreground="White" FontWeight="Bold" CornerRadius="6"/>
				</StackPanel>
			</Grid>

			<TextBlock Grid.Row="1" Text="{Binding CurrentLocalPath}" FontSize="12" Foreground="#4A4A5A" TextTrimming="CharacterEllipsis" ToolTip.Tip="{Binding CurrentLocalPath}"/>
		</Grid>

		<Border Grid.Row="1" Background="#1E1E2D" CornerRadius="12" BorderBrush="#2B2B40" BorderThickness="1">
			<Grid RowDefinitions="Auto, *">

				<Grid Grid.Row="0" ColumnDefinitions="Auto, 3*, 1.5*, 1.5*, Auto" Margin="20,15,20,10">
					<TextBlock Grid.Column="1" Text="NAME" Foreground="#A1A5B7" FontWeight="Bold" FontSize="12"/>
					<TextBlock Grid.Column="2" Text="TYPE" Foreground="#A1A5B7" FontWeight="Bold" FontSize="12"/>
					<TextBlock Grid.Column="3" Text="SIZE" Foreground="#A1A5B7" FontWeight="Bold" FontSize="12"/>
					<TextBlock Grid.Column="4" Text="ACTIONS" Foreground="#A1A5B7" FontWeight="Bold" FontSize="12" Width="140" TextAlignment="Center"/>
				</Grid>

				<Rectangle Grid.Row="0" Height="1" Fill="#2B2B40" VerticalAlignment="Bottom"/>

				<ListBox Grid.Row="1" ItemsSource="{Binding Files}" Background="Transparent" Margin="10" DoubleTapped="OnItemDoubleTapped">
					<ListBox.ItemTemplate>
						<DataTemplate>
							<Grid ColumnDefinitions="Auto, 3*, 1.5*, 1.5*, Auto" Margin="10,8" Background="Transparent">

								<TextBlock Grid.Column="0" Text="{Binding Icon}" FontSize="16" Margin="0,0,10,0" VerticalAlignment="Center"/>

								<TextBlock Grid.Column="1" Text="{Binding Name}" Foreground="White" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" Margin="0,0,15,0"/>
								<TextBlock Grid.Column="2" Text="{Binding FileType}" Foreground="#A1A5B7" VerticalAlignment="Center"/>
								<TextBlock Grid.Column="3" Text="{Binding SizeFormatted}" Foreground="#A1A5B7" VerticalAlignment="Center"/>

								<StackPanel Grid.Column="4" Orientation="Horizontal" Spacing="10" Width="140" HorizontalAlignment="Right">
									<Button Content="Open" Command="{Binding $parent[UserControl].((vm:HostedFilesViewModel)DataContext).OpenFileCommand}" CommandParameter="{Binding FullPath}" Background="#3E97FF" Foreground="White" CornerRadius="6" Width="60" HorizontalContentAlignment="Center"/>
									<Button Content="Delete" Command="{Binding $parent[UserControl].((vm:HostedFilesViewModel)DataContext).DeleteFileCommand}" CommandParameter="{Binding FullPath}" Background="#F1416C" Foreground="White" CornerRadius="6" Width="60" HorizontalContentAlignment="Center"/>
								</StackPanel>
							</Grid>
						</DataTemplate>
					</ListBox.ItemTemplate>
				</ListBox>

			</Grid>
		</Border>

	</Grid>
</UserControl>