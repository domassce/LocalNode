<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:LocalFileHosting.UI.ViewModels"
             x:Class="LocalFileHosting.UI.Views.SettingsView"
             x:DataType="vm:SettingsViewModel">

	<StackPanel Spacing="20">
		<TextBlock Text="Application Settings" FontSize="18" FontWeight="SemiBold" Foreground="White"/>

		<Border Background="#1E1E2D" CornerRadius="12" Padding="30" BorderBrush="#2B2B40" BorderThickness="1" HorizontalAlignment="Left">
			<StackPanel Spacing="20" HorizontalAlignment="Left">

				<StackPanel Spacing="5">
					<TextBlock Text="Display Name" Foreground="#A1A5B7"/>
					<TextBox Text="{Binding DisplayName}" Background="#151521" Foreground="White" CornerRadius="6" Width="300" HorizontalAlignment="Left"/>
				</StackPanel>

				<Grid ColumnDefinitions="Auto, Auto">
					<StackPanel Grid.Column="0" Spacing="5" Margin="0,0,15,0">
						<TextBlock Text="Hosting Port" Foreground="#A1A5B7"/>
						<TextBox Text="{Binding DefaultPort}" Background="#151521" Foreground="White" CornerRadius="6" Width="100"/>
					</StackPanel>

					<StackPanel Grid.Column="1" Spacing="5">
						<TextBlock Text="Room Password" Foreground="#A1A5B7"/>
						<TextBox Text="{Binding RoomPassword}" PasswordChar="*" Background="#151521" Foreground="White" CornerRadius="6" Width="185"/>
					</StackPanel>
				</Grid>

				<StackPanel Spacing="5">
					<TextBlock Text="Hosting Folder Path" Foreground="#A1A5B7"/>
					<Grid ColumnDefinitions="Auto, Auto">
						<TextBox Text="{Binding DefaultHostFolder}" Grid.Column="0" IsReadOnly="True" Background="#151521" Foreground="White" CornerRadius="6,0,0,6" Width="300"/>
						<Button Grid.Column="1" Content="Browse..." Click="OnBrowseFolderClicked" Background="#3E97FF" Foreground="White" CornerRadius="0,6,6,0"/>
					</Grid>
				</StackPanel>

				<StackPanel Spacing="5">
					<TextBlock Text="Save System Logs To" Foreground="#A1A5B7"/>
					<Grid ColumnDefinitions="Auto, Auto">
						<TextBox Text="{Binding LogDirectory}" Grid.Column="0" IsReadOnly="True" Background="#151521" Foreground="White" CornerRadius="6,0,0,6" Width="300" Watermark="App directory if left empty..."/>
						<Button Grid.Column="1" Content="Browse..." Click="OnBrowseLogFolderClicked" Background="#3E97FF" Foreground="White" CornerRadius="0,6,6,0"/>
					</Grid>
				</StackPanel>

				<StackPanel Orientation="Horizontal" Spacing="15" Margin="0,10,0,0">
					<Button Content="Save Settings" Command="{Binding SaveSettingsCommand}" Background="#50CD89" Foreground="White" FontWeight="Bold" Padding="20,10" CornerRadius="8"/>
					<TextBlock Text="{Binding StatusMessage}" Foreground="#009EF7" VerticalAlignment="Center" Width="250" TextWrapping="Wrap"/>
				</StackPanel>

			</StackPanel>
		</Border>
	</StackPanel>
</UserControl>