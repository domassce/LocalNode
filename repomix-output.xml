							<TextBox Grid.Column="0" Text="{Binding ServerUrl}" Watermark="Server URL" Margin="0,0,15,0" Background="#151521" Foreground="White"/>
							<TextBox Grid.Column="1" Text="{Binding RoomPassword}" PasswordChar="*" Watermark="Password (Optional)" Margin="0,0,15,0" Background="#151521" Foreground="White"/>
							<Button Grid.Column="2" Content="Connect" Command="{Binding ConnectCommand}" Background="#009EF7" Foreground="White" FontWeight="Bold" Padding="20,8" CornerRadius="6"/>
						</Grid>
