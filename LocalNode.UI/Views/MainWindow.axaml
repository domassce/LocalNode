<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:LocalNode.UI.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1024" d:DesignHeight="768"
        x:Class="LocalNode.UI.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="Local File Hosting"
        RequestedThemeVariant="Dark"
        Width="1024" Height="768"
        WindowStartupLocation="CenterScreen">

	<Design.DataContext>
		<vm:MainWindowViewModel/>
	</Design.DataContext>

	<Window.Styles>
		<Style Selector="RadioButton.NavButton">
			<Setter Property="Background" Value="Transparent"/>
			<Setter Property="Foreground" Value="#A1A5B7"/>
			<Setter Property="Padding" Value="15,12"/>
			<Setter Property="CornerRadius" Value="8"/>
			<Setter Property="HorizontalAlignment" Value="Stretch"/>
			<Setter Property="HorizontalContentAlignment" Value="Left"/>
			<Setter Property="Template">
				<ControlTemplate>
					<Border Background="{TemplateBinding Background}" CornerRadius="{TemplateBinding CornerRadius}">
						<ContentPresenter Content="{TemplateBinding Content}" Margin="{TemplateBinding Padding}"
                                          HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="Center"/>
					</Border>
				</ControlTemplate>
			</Setter>
		</Style>

		<Style Selector="RadioButton.NavButton:pointerover">
			<Setter Property="Background" Value="#252538"/>
			<Setter Property="Foreground" Value="White"/>
		</Style>

		<Style Selector="RadioButton.NavButton:checked">
			<Setter Property="Background" Value="#2B2B40"/>
			<Setter Property="Foreground" Value="White"/>
		</Style>
	</Window.Styles>

	<Grid ColumnDefinitions="250, *">

		<Border Grid.Column="0" Background="#1E1E2D" BorderBrush="#2B2B40" BorderThickness="0,0,1,0">
			<Grid RowDefinitions="Auto, *, Auto">

				<StackPanel Grid.Row="0" Orientation="Horizontal" Margin="20,25,20,40" Spacing="15" VerticalAlignment="Center">

					<Border Background="#151521" Padding="8" CornerRadius="10" BorderBrush="#2B2B40" BorderThickness="1">
						<Path Data="M10,4H4C2.89,4 2,4.89 2,6V18A2,2 0 0,0 4,20H20A2,2 0 0,0 22,18V8C22,6.89 21.1,6 20,6H12L10,4Z"
                              Fill="#009EF7" Width="20" Height="20" Stretch="Uniform"
                              HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,2,0,0"/>
					</Border>

					<TextBlock VerticalAlignment="Center" FontSize="22" LetterSpacing="1">
						<Run Text="Local" FontWeight="Medium" Foreground="#A1A5B7"/><Run Text="Node" FontWeight="Heavy" Foreground="White"/>		
					</TextBlock>

				</StackPanel>

				<StackPanel Grid.Row="1" Spacing="5" Margin="10,0">
					<RadioButton Classes="NavButton" Content="Dashboard" Command="{Binding NavigateCommand}" CommandParameter="Dashboard"
                                 GroupName="SidebarNav" IsChecked="True"/>

					<RadioButton Classes="NavButton" Content="Hosted Files" Command="{Binding NavigateCommand}" CommandParameter="Hosted Files"
                                 GroupName="SidebarNav"/>

					<RadioButton Classes="NavButton" Content="Network Client" Command="{Binding NavigateCommand}" CommandParameter="Network Client"
                                 GroupName="SidebarNav"/>

					<RadioButton Classes="NavButton" Content="Settings" Command="{Binding NavigateCommand}" CommandParameter="Settings"
                                 GroupName="SidebarNav"/>
				</StackPanel>

				<TextBlock Grid.Row="2" Text="v0.0.3" Foreground="#4A4A5A" FontSize="12" HorizontalAlignment="Center" Margin="0,0,0,20"/>
			</Grid>
		</Border>

		<Border Grid.Column="1" Background="#151521">
			<Grid RowDefinitions="Auto, *">

				<Border Grid.Row="0" Background="#151521" BorderBrush="#2B2B40" BorderThickness="0,0,0,1" Height="70" Padding="30,0">
					<TextBlock Text="{Binding PageTitle}" VerticalAlignment="Center" FontSize="22" FontWeight="SemiBold" Foreground="White"/>
				</Border>

				<Border Grid.Row="1" Margin="30" CornerRadius="12">
					<ContentControl Content="{Binding CurrentPageContent}" />
				</Border>
			</Grid>
		</Border>

	</Grid>
</Window>