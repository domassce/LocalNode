<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:LocalNode.UI.ViewModels"
             x:Class="LocalNode.UI.Views.DashboardView"
             x:DataType="vm:DashboardViewModel">

	<StackPanel Spacing="20">
		<TextBlock Text="System Overview" FontSize="18" FontWeight="SemiBold" Foreground="White"/>

		<UniformGrid Columns="3">

			<Border Background="#2B2B40" CornerRadius="12" Padding="20" Margin="0,0,10,0">
				<StackPanel Spacing="10">
					<TextBlock Text="Total Files" Foreground="#A1A5B7" FontSize="14" FontWeight="Medium"/>
					<TextBlock Text="{Binding TotalFiles}" Foreground="White" FontSize="28" FontWeight="Bold"/>
				</StackPanel>
			</Border>

			<Border Background="#2B2B40" CornerRadius="12" Padding="20" Margin="10,0,10,0">
				<StackPanel Spacing="10">
					<TextBlock Text="Storage Used" Foreground="#A1A5B7" FontSize="14" FontWeight="Medium"/>
					<TextBlock Text="{Binding TotalSize}" Foreground="#009EF7" FontSize="28" FontWeight="Bold"/>
				</StackPanel>
			</Border>

			<Border Background="#2B2B40" CornerRadius="12" Padding="20" Margin="10,0,0,0">
				<StackPanel Spacing="10">
					<TextBlock Text="Last Updated" Foreground="#A1A5B7" FontSize="14" FontWeight="Medium"/>
					<TextBlock Text="{Binding LastUpdated}" Foreground="#50CD89" FontSize="28" FontWeight="Bold"/>
				</StackPanel>
			</Border>

		</UniformGrid>

		<TextBlock Text="Server Status" FontSize="18" FontWeight="SemiBold" Foreground="White" Margin="0,20,0,0"/>

		<Border Background="#1E1E2D" CornerRadius="12" Padding="30" BorderBrush="#2B2B40" BorderThickness="1">
			<Grid ColumnDefinitions="*, Auto">

				<StackPanel Grid.Column="0" VerticalAlignment="Center">
					<TextBlock Text="{Binding ServerStatusMessage}" Foreground="White" FontSize="18" Margin="0,5,0,0"/>
				</StackPanel>

				<Button Grid.Column="1" Command="{Binding ToggleHostingCommand}"
                        Background="#3E97FF"
                        CornerRadius="8" Padding="30,15">
					<Panel>
						<StackPanel Orientation="Horizontal" Spacing="10" IsVisible="{Binding !IsHosting}">
							<TextBlock Text="▶" Foreground="#50CD89" FontSize="16" VerticalAlignment="Center"/>
							<TextBlock Text="START SERVER" Foreground="White" FontSize="16" FontWeight="Bold"/>
						</StackPanel>

						<StackPanel Orientation="Horizontal" Spacing="10" IsVisible="{Binding IsHosting}">
							<TextBlock Text="■" Foreground="#F1416C" FontSize="16" VerticalAlignment="Center"/>
							<TextBlock Text="STOP SERVER" Foreground="White" FontSize="16" FontWeight="Bold"/>
						</StackPanel>
					</Panel>
				</Button>

			</Grid>
		</Border>
	</StackPanel>
</UserControl>